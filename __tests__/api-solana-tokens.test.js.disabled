/**
 * Test suite for api/solana-tokens.js
 * Tests Solana token creation and management functions
 */

// Mock dependencies before requiring the module
jest.mock('@solana/spl-token', () => ({
  createMint: jest.fn(),
  getOrCreateAssociatedTokenAccount: jest.fn(),
  mintTo: jest.fn(),
  getMint: jest.fn()
}));

jest.mock('../api/logger', () => ({
  createLogger: () => ({
    info: jest.fn(),
    error: jest.fn(),
    warn: jest.fn(),
    debug: jest.fn()
  })
}));

describe('Solana Tokens Module', () => {
  let splToken;

  beforeEach(() => {
    jest.clearAllMocks();
    jest.resetModules();
    
    // Mock the payer module before requiring solana-tokens
    jest.doMock('../api/payer', () => ({
      payer: {
        publicKey: { toBase58: () => 'test-public-key' },
        secretKey: new Uint8Array(64)
      }
    }));
    
    // Now get the mocked splToken
    splToken = require('@solana/spl-token');
  });

  afterEach(() => {
    jest.resetModules();
  });

  describe('Module Export Verification', () => {
    test('should export token management functions', () => {
      // Test that the module exports the expected functions
      splToken.createMint.mockImplementation(() => {});
      splToken.getOrCreateAssociatedTokenAccount.mockImplementation(() => {});
      splToken.mintTo.mockImplementation(() => {});
      splToken.getMint.mockImplementation(() => {});
      
      expect(splToken.createMint).toBeDefined();
      expect(splToken.getOrCreateAssociatedTokenAccount).toBeDefined();
      expect(splToken.mintTo).toBeDefined();
      expect(splToken.getMint).toBeDefined();
    });
  });

  describe('Token Creation - Function Structure', () => {
    test('should have createMint function', () => {
      expect(typeof splToken.createMint).toBe('function');
    });

    test('should have getOrCreateAssociatedTokenAccount function', () => {
      expect(typeof splToken.getOrCreateAssociatedTokenAccount).toBe('function');
    });

    test('should have mintTo function', () => {
      expect(typeof splToken.mintTo).toBe('function');
    });

    test('should have getMint function', () => {
      expect(typeof splToken.getMint).toBe('function');
    });
  });

  describe('Token Functions - Mock Behavior', () => {
    test('createMint should be callable', async () => {
      splToken.createMint.mockResolvedValue({ toBase58: () => 'mint-123' });
      
      const result = await splToken.createMint(
        {},  // connection
        {},  // payer
        {},  // mint authority
        {},  // freeze authority
        0    // decimals
      );
      
      expect(result).toBeDefined();
      expect(result.toBase58()).toBe('mint-123');
    });

    test('getOrCreateAssociatedTokenAccount should return token account', async () => {
      splToken.getOrCreateAssociatedTokenAccount.mockResolvedValue({
        address: { toBase58: () => 'token-account-123' }
      });
      
      const result = await splToken.getOrCreateAssociatedTokenAccount({}, {}, {}, {});
      
      expect(result).toBeDefined();
      expect(result.address.toBase58()).toBe('token-account-123');
    });

    test('mintTo should return transaction signature', async () => {
      splToken.mintTo.mockResolvedValue('tx-sig-123');
      
      const result = await splToken.mintTo({}, {}, {}, {}, {}, 1);
      
      expect(result).toBe('tx-sig-123');
    });

    test('getMint should return mint information', async () => {
      splToken.getMint.mockResolvedValue({
        supply: { toString: () => '1000' },
        decimals: 0
      });
      
      const result = await splToken.getMint({}, {});
      
      expect(result).toBeDefined();
      expect(result.supply.toString()).toBe('1000');
      expect(result.decimals).toBe(0);
    });
  });

  describe('Error Handling', () => {
    test('createMint should handle errors', async () => {
      splToken.createMint.mockRejectedValue(new Error('Network error'));
      
      await expect(splToken.createMint({}, {}, {}, {}, 0))
        .rejects
        .toThrow('Network error');
    });

    test('getOrCreateAssociatedTokenAccount should handle errors', async () => {
      splToken.getOrCreateAssociatedTokenAccount.mockRejectedValue(
        new Error('ATA error')
      );
      
      await expect(splToken.getOrCreateAssociatedTokenAccount({}, {}, {}, {}))
        .rejects
        .toThrow('ATA error');
    });

    test('mintTo should handle errors', async () => {
      splToken.mintTo.mockRejectedValue(new Error('Mint error'));
      
      await expect(splToken.mintTo({}, {}, {}, {}, {}, 1))
        .rejects
        .toThrow('Mint error');
    });

    test('getMint should handle errors', async () => {
      splToken.getMint.mockRejectedValue(new Error('Token not found'));
      
      await expect(splToken.getMint({}, {}))
        .rejects
        .toThrow('Token not found');
    });
  });

  describe('Mock Call Tracking', () => {
    test('should track createMint calls', async () => {
      splToken.createMint.mockResolvedValue({ toBase58: () => 'mint' });
      
      await splToken.createMint({}, {}, {}, {}, 0);
      
      expect(splToken.createMint).toHaveBeenCalled();
      expect(splToken.createMint).toHaveBeenCalledTimes(1);
    });

    test('should track multiple calls with different arguments', async () => {
      splToken.createMint.mockResolvedValue({ toBase58: () => 'mint' });
      
      await splToken.createMint({}, {}, {}, {}, 0);
      await splToken.createMint({}, {}, {}, {}, 8);
      
      expect(splToken.createMint).toHaveBeenCalledTimes(2);
    });

    test('should track mint amount in mintTo calls', async () => {
      splToken.mintTo.mockResolvedValue('sig');
      
      await splToken.mintTo({}, {}, {}, {}, {}, 1);
      await splToken.mintTo({}, {}, {}, {}, {}, 10);
      
      expect(splToken.mintTo).toHaveBeenCalledTimes(2);
    });
  });

  describe('Response Format Validation', () => {
    test('createMint response should have toBase58 method', async () => {
      const mockResponse = {
        toBase58: jest.fn(() => 'base58-encoded-address')
      };
      splToken.createMint.mockResolvedValue(mockResponse);
      
      const result = await splToken.createMint({}, {}, {}, {}, 0);
      
      expect(result.toBase58).toBeDefined();
      expect(typeof result.toBase58).toBe('function');
      expect(result.toBase58()).toBe('base58-encoded-address');
    });

    test('getOrCreateAssociatedTokenAccount response should have address property', async () => {
      const mockResponse = {
        address: { toBase58: () => 'token-account' }
      };
      splToken.getOrCreateAssociatedTokenAccount.mockResolvedValue(mockResponse);
      
      const result = await splToken.getOrCreateAssociatedTokenAccount({}, {}, {}, {});
      
      expect(result).toHaveProperty('address');
      expect(result.address.toBase58()).toBe('token-account');
    });

    test('mintTo response should be a string signature', async () => {
      splToken.mintTo.mockResolvedValue('signature-string-123');
      
      const result = await splToken.mintTo({}, {}, {}, {}, {}, 1);
      
      expect(typeof result).toBe('string');
      expect(result).toMatch(/signature/);
    });

    test('getMint response should have supply and decimals', async () => {
      const mockResponse = {
        supply: { toString: () => '1000' },
        decimals: 6,
        owner: 'owner-address'
      };
      splToken.getMint.mockResolvedValue(mockResponse);
      
      const result = await splToken.getMint({}, {});
      
      expect(result).toHaveProperty('supply');
      expect(result).toHaveProperty('decimals');
      expect(result.supply.toString()).toBe('1000');
      expect(result.decimals).toBe(6);
    });
  });
});
