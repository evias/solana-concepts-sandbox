{
  "name": "solana-concepts-sandbox",
  "version": "0.12.4",
  "description": "Solana Concepts - SPL Token Mints, Credentials, Attestations (SAS), Transactions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --watch",
    "build": "npx @tailwindcss/cli -i ./assets/base.css -o ./assets/base.min.css",
    "watch": "npx @tailwindcss/cli -i ./assets/base.css -o ./assets/base.min.css --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:init": "node scripts/db-init.js",
    "db:seed": "node scripts/db-seed.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:fresh": "npm run db:init && npm run db:seed && npm run db:migrate",
    "docs:generate": "node scripts/generate-docs.js"
  },
  "dependencies": {
    "@solana/kit": "^5.5.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "sas-lib": "^1.0.10",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.14.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  }
}
