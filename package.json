{
  "name": "solana-concepts-sandbox",
  "version": "1.0.0",
  "description": "Concept Sandbox using Solana token accounts and mandates",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --watch",
    "build": "npx @tailwindcss/cli -i ./assets/base.css -o ./assets/base.min.css",
    "watch": "npx @tailwindcss/cli -i ./assets/base.css -o ./assets/base.min.css --watch",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.10.0",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "jest": "^30.4.2"
  }
}
