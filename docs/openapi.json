                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "credential": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    },
                    "caregiver": {
                      "type": "string"
                    },
                    "wallet": {
                      "type": "string"
                    },
